{
  "name": "roadsos",
  "version": "1.0.0",
  "description": "RoadSoS — AI-Powered Emergency Road Safety App",
  "private": true,
  "scripts": {
    "android:init": "npx --yes @capacitor/cli@latest add android",
    "android:sync": "npx --yes @capacitor/cli@latest sync android",
    "android:open": "npx --yes @capacitor/cli@latest open android",
    "android:run": "npx --yes @capacitor/cli@latest run android",
    "android:build": "cd android && gradlew.bat assembleDebug",
    "android:build-release": "cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/motion": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0"
  }
}
